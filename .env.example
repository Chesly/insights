# Copy this file to .env.local for local development.
# In production, set these in your hosting platform's environment variables
# dashboard (e.g. Vercel → Project → Settings → Environment Variables).
# All are optional — features they control are simply skipped when unset.

# Google Analytics 4 — Admin > Data Streams > your stream > Measurement ID
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Google Tag Manager — container ID, format GTM-XXXXXXX
NEXT_PUBLIC_GTM_ID=

# Microsoft Clarity — Settings > Setup > Project ID
NEXT_PUBLIC_CLARITY_PROJECT_ID=

# Google Search Console — HTML tag verification method, the "content" value only
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Bing Webmaster Tools — HTML tag verification method, the "content" value only
NEXT_PUBLIC_BING_SITE_VERIFICATION=
